# ============================================================
# Copy this file to .env and fill in your actual values
# ============================================================

# Django
SECRET_KEY=your-very-secret-django-key-change-this-to-random-string
DEBUG=True

# PostgreSQL Database
DB_NAME=hms_db
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here
DB_HOST=localhost
DB_PORT=5432

# Gmail (for sending emails via the serverless function)
# Use an App Password, not your real Gmail password
# Get it from: Google Account > Security > App Passwords
EMAIL_FROM=your_gmail@gmail.com
EMAIL_PASSWORD=your_16_char_app_password

# Serverless Email Service URL (local)
SERVERLESS_EMAIL_URL=http://localhost:3000/dev/send-email
